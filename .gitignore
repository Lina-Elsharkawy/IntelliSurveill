# Node.js

# Ignore node_modules in root and common workspaces
node_modules/
/backend/node_modules/
/frontend/node_modules/


# Environment variables
**/*.env
.env
!**/*.env.example
!**/.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE / Editor specific
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln

# Flink / Java / Maven
target/
*.class
*.jar

# Backend — Python compiled/cache artifacts
__pycache__/
*.pyc
*.pyo

