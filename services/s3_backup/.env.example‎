# ── Target S3-compatible store ─────────────────────────
# For AWS S3: leave ENDPOINT_URL empty, set real AWS keys
# For MinIO (testing): set ENDPOINT_URL to your MinIO
AWS_S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=my-evidence-backup
AWS_S3_REGION=us-east-1
AWS_S3_PREFIX=evidence-backup/

# ── MinIO source ───────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=evidence

# ── Backup config ──────────────────────────────────────
BACKUP_PREFIXES=faces/
BACKUP_INTERVAL_HOURS=6
SYNC_STATE_FILE=/data/sync_state.json
CONFIG_FILE=/data/backup_config.json

# ── API ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8020
LOG_LEVEL=INFO